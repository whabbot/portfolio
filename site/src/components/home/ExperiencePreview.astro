---
import SectionHeading from '@/components/SectionHeading.astro';

const sectionHref = '/cv';
const sectionTitle = 'Experience';
const basePath = '/experience';

const items = [
  { slug: 'lead-engineer', text: 'Led platform migration reducing deployment time by 60%.' },
  { slug: 'design-systems', text: 'Established design system adopted across 4 product teams.' },
  {
    slug: 'product-engineering',
    text: 'Shipped user research-driven features that improved retention.',
  },
  { slug: 'scaling', text: 'Scaled frontend architecture to support 10x traffic growth.' },
];
---

<section aria-label="Experience preview" class="preview-section preview-section--warm">
  <div class="mx-auto max-w-3xl px-6 py-6 md:px-8 md:py-8">
    <div class="mb-10">
      <SectionHeading href={sectionHref}>{sectionTitle}</SectionHeading>
    </div>

    <ul class="space-y-4" role="list">
      {
        items.map(({ slug, text }) => (
          <li class="preview-item">
            <a href={`${basePath}/${slug}`} class="preview-link">
              {text}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
