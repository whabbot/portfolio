---
import SectionHeading from '@/components/SectionHeading.astro';

const sectionHref = '/projects';
const sectionTitle = 'Projects';
const basePath = '/projects';

const items = [
  { slug: 'design-system', text: 'Design system migration' },
  { slug: 'checkout-flow', text: 'Checkout flow optimisation' },
  { slug: 'api-gateway', text: 'API gateway redesign' },
  { slug: 'analytics-dashboard', text: 'Analytics dashboard v2' },
  { slug: 'mobile-app', text: 'Mobile app prototype' },
];
---

<section aria-label="Projects preview" class="preview-section preview-section--creative">
  <div class="mx-auto max-w-3xl px-6 py-6 md:px-8 md:py-8">
    <div class="mb-10">
      <SectionHeading href={sectionHref}>{sectionTitle}</SectionHeading>
    </div>

    <ul class="space-y-4" role="list">
      {
        items.map(({ slug, text }) => (
          <li class="preview-item">
            <a href={`${basePath}/${slug}`} class="preview-link">
              {text}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
