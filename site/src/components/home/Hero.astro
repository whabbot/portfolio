---
import { Button } from '@/components/ui/button';
---

<section aria-label="Hero" class="relative overflow-hidden">
  <div class="mx-auto max-w-3xl px-6 pt-20 pb-10 md:px-8 md:pt-24 md:pb-12">
    <div class="relative md:pl-12">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -left-10 top-4 h-28 w-28 rounded-full bg-primary/10 blur-2xl"
      >
      </div>

      <h1 class="max-w-[32ch] text-balance">
        Frontend leaning fullstack engineer building user-centric products.
      </h1>

      <div class="mt-10 flex flex-wrap gap-3">
        <Button asChild>
          <a href="/projects">Explore Projects →</a>
        </Button>
        <Button variant="outline" asChild>
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer">
            LinkedIn → <span class="sr-only">(opens in a new tab)</span>
          </a>
        </Button>
      </div>
    </div>
  </div>
</section>
