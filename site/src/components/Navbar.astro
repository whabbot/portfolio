---
import ThemeToggle from './ThemeToggle.astro';
import MobileNav from './MobileNav';

const { pathname } = Astro.url;

const links = [{ href: '/projects', label: 'Projects' }];

function isActive(href: string): boolean {
  if (href === '/') {
    return pathname === '/' || pathname === '';
  }
  return pathname === href || pathname === `${href}/`;
}
---

<header
  class="sticky top-0 z-40 w-full border-b border-default bg-background/95 backdrop-blur-sm supports-backdrop-filter:bg-background/80"
>
  <nav
    class="mx-auto flex h-14 max-w-4xl items-center justify-between px-6 md:px-8"
    aria-label="Main"
  >
    <a href="/" class="text-lg font-medium text-foreground hover:text-primary transition-colors">
      Clearcraft
    </a>

    <div class="hidden items-center gap-6 sm:flex">
      {
        links.map(({ href, label }) => (
          <a
            href={href}
            class:list={['nav-link', 'transition-underline']}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        ))
      }
      <ThemeToggle />
    </div>

    <div class="sm:hidden">
      <MobileNav client:media="(max-width: 639px)" pathname={pathname} />
    </div>
  </nav>
</header>

<style>
  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color 200ms ease-in-out;
  }

  .nav-link:hover,
  .nav-link[aria-current='page'] {
    color: var(--color-text);
  }
</style>
