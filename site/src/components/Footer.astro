<footer class="border-t border-default bg-background" role="contentinfo">
  <div class="mx-auto max-w-4xl px-6 py-6 md:px-8">
    <div class="flex justify-start gap-6 sm:justify-end">
      <a
        href="https://github.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        aria-label="View GitHub profile"
      >
        GitHub
      </a>
      <a
        href="https://medium.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        aria-label="View Medium profile"
      >
        Medium
      </a>
      <a
        href="https://linkedin.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        aria-label="View LinkedIn profile"
      >
        LinkedIn
      </a>
    </div>
  </div>
</footer>
