---
import CardSurface from '../CardSurface.astro';
import TagPill from '../TagPill.astro';

interface Props {
  slug: string;
  title: string;
  description: string;
  techTags: string[];
  githubUrl: string;
  class?: string;
}

const { slug, title, description, techTags, githubUrl, class: className } = Astro.props;
const href = `/projects/${slug}`;
---

<article class:list={[className]}>
  <CardSurface
    hoverLift
    class="group relative overflow-hidden p-5 sm:p-6 focus-within:ring-1 focus-within:ring-accent-creative/25 group-hover:border-accent-creative/40 focus-within:border-accent-creative/40 before:pointer-events-none before:absolute before:inset-0 before:bg-linear-to-br before:from-accent-creative/10 before:to-transparent before:opacity-0 before:transition-opacity before:duration-200 before:ease-in-out group-hover:before:opacity-100 focus-within:before:opacity-100"
  >
    <!-- Overlay link: makes the whole tile clickable (behind content) -->
    <a href={href} aria-label={`Open project: ${title}`} class="absolute inset-0 z-0 rounded-xl"
    ></a>

    <div
      class="relative z-10 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between sm:gap-4 pointer-events-none"
    >
      <div class="min-w-0 pr-2">
        <h3 class="truncate text-lg font-semibold leading-tight">{title}</h3>
        <p class="mt-2 text-sm text-muted-foreground">{description}</p>
      </div>

      <a
        href={githubUrl}
        target="_blank"
        rel="noreferrer"
        aria-label="View source on GitHub"
        title="View source on GitHub (opens in a new tab)"
        class="relative z-20 inline-flex w-fit items-center gap-2 rounded-full border border-default bg-muted/40 px-3 py-1.5 text-xs font-medium text-muted-foreground transition-colors hover:bg-muted hover:text-foreground pointer-events-auto sm:ml-auto"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 fill-current">
          <path
            d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.168 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.455-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.087.636-1.337-2.22-.253-4.555-1.11-4.555-4.943 0-1.092.39-1.986 1.029-2.686-.103-.253-.446-1.27.098-2.646 0 0 .84-.269 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.57 9.57 0 0 1 2.504.337c1.909-1.295 2.748-1.026 2.748-1.026.546 1.376.202 2.393.1 2.646.64.7 1.028 1.594 1.028 2.686 0 3.842-2.338 4.687-4.566 4.935.36.31.68.92.68 1.852 0 1.336-.013 2.415-.013 2.744 0 .268.18.58.688.482A10.016 10.016 0 0 0 22 12c0-5.523-4.477-10-10-10Z"
          ></path>
        </svg>
        <span>GitHub</span>
        <span aria-hidden="true">↗</span>
      </a>
    </div>

    <div class="relative z-10 mt-4 flex flex-wrap gap-2 pointer-events-none">
      {techTags.map((tag) => <TagPill>{tag}</TagPill>)}
    </div>

    <div class="relative z-10 mt-4 pointer-events-none">
      <a
        href={href}
        class="relative z-20 inline-flex items-center text-sm font-medium text-accent-creative transition-colors hover:text-accent-creative/90 pointer-events-auto"
      >
        See decisions →
      </a>
    </div>
  </CardSurface>
</article>
