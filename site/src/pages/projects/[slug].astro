---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectDetail from '../../components/projects/ProjectDetail.astro';
import { normalizeProjectDetailPage } from '@/lib/mappers';
import { fetchAllProjectSlugs, fetchProjectBySlug } from '@/lib/sanity';

export async function getStaticPaths() {
  const rows = await fetchAllProjectSlugs();
  return rows.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error('Missing project slug param.');
}

const raw = await fetchProjectBySlug(slug);
if (!raw) {
  throw new Error(`Missing project data for slug: ${slug}`);
}
const detail = normalizeProjectDetailPage(raw);

if (!detail) {
  throw new Error(`Project slug "${slug}" failed normalization. Check required fields.`);
}
---

<BaseLayout title={`${detail.title} — Clearcraft`}>
  <div class="mx-auto max-w-6xl px-6 py-16">
    <ProjectDetail
      title={detail.title}
      summary={detail.summary}
      sections={detail.sections}
      githubUrl={detail.githubUrl}
      liveDemoUrl={detail.liveDemoUrl}
    />
  </div>
</BaseLayout>
