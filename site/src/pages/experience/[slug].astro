---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'placeholder' } },
    { params: { slug: 'lead-engineer' } },
    { params: { slug: 'design-systems' } },
    { params: { slug: 'product-engineering' } },
    { params: { slug: 'scaling' } },
  ];
}

const { slug } = Astro.params;
---

<BaseLayout title={`${slug} — Clearcraft`}>
  <div class="mx-auto max-w-3xl px-6 py-16">
    <h1>{slug}</h1>
    <p class="mt-4 text-muted-foreground">Experience detail — content coming soon.</p>
  </div>
</BaseLayout>
