---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <div class="mx-auto max-w-3xl px-6 py-16">
    <h1>Page not found</h1>
    <p class="mt-4 text-muted-foreground">This page doesn't exist.</p>
    <a
      href="/"
      class="mt-6 inline-block text-primary hover:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
    >
      Back to home →
    </a>
  </div>
</BaseLayout>
